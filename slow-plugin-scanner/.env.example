# Plugin build mode: "free" or "premium"
# - free: Limited scans with upgrade prompts
# - premium: Full functionality, no limits
# PIA_MODE=free

# Maximum plugins to scan in free mode
# Ignored in premium mode
# PIA_FREE_PLUGIN_LIMIT=3

# URL for premium upgrade/purchase page
# Shown in upgrade prompts in free mode
# PIA_PREMIUM_URL=https://your-stripe-purchase-link